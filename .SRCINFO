pkgbase = codex-app-electron-port-bin
	pkgdesc = Unofficial Electron-port repackaging of Codex desktop app from macOS DMG
	pkgver = 2026.03.03
	pkgrel = 1
	url = https://github.com/Tomakin/codex-app-electron-port-bin
	install = codex-app-electron-port-bin.install
	arch = x86_64
	license = custom
	makedepends = p7zip
	makedepends = asar
	depends = electron
	depends = bash
	optdepends = nodejs: runtime dependency for Codex CLI and native rebuild helper
	optdepends = pnpm: needed for native module rebuild helper
	optdepends = base-devel: needed for native module rebuild helper
	optdepends = python: needed for native module rebuild helper
	optdepends = sudo: allows native rebuild helper to update files under /opt
	optdepends = paru: optional helper for package auto-update command
	optdepends = yay: optional helper for package auto-update command
	noextract = Codex.dmg
	options = !strip
	source = Codex.dmg::https://persistent.oaistatic.com/codex-app-prod/Codex.dmg
